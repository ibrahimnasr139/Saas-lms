{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtOptions": {
    "Issuer": "https://api.waey.online",
    "Audience": "https://waey.online",
    "ExpiryMinutes": 60

  },
  "MailOptions": {
    "Email": "hadeer_malek@mail.waey.online",
    "FromName": "Yalla Learn",
    "BaseUrl": "https://api.brevo.com/v3",
    "Endpoint": "smtp/email"
  },
  "BunnyOptions": {
    "StorageZoneName": "saas-lms-storage",
    "HostName": "storage.bunnycdn.com",
    "CdnUrl": "https://saas-lms-cdn.b-cdn.net/",
    "VideoLibraryId": "596405"
  },
  "FileOptions": {
    "VideoMaxSize": 1073741824,
    "ImageMaxSize": 5242880,
    "DocumentMaxSize": 20971520
  },
  "AiTranscriptionOptions": {
    "Url": "https://ai.waey.online/api/embed-file",
    "CallbackUrl": "https://api.waey.online/api/files/callback"
  },
  "AiOptions": {
    "QuestionEndPoint": "https://ai.waey.online/api/ai-generate-question",
    "AiAssistantEndPoint": "https://ai.waey.online/api/ai-assistant",
    "AskAiEndPoint": "https://ai.waey.online/api/ask-ai",
    "GenerateFlashCardsEndPoint": "https://ai.waey.online/api/generate-flashcards"
  },
  "ZoomOptions": {
    "ClientId": "hOfULPAZQNSitMeTCjsJBw",
    "RedirectUri": "https://api.waey.online/api/tenant/integrations/zoom/callback",
    "WebhookUrl": "https://api/tenant/integrations/zoom/webhooks",
    "DeauthorizationUrl": "https://api.waey.online/api/zoom/oauth/deauthorize"
  },
  "AllowedOrigins": [ "waey.online" ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd-MM HH:mm:ss} {Level:u3}] |{SourceContext}| {NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/lms-Api-.log.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "Saas-lms"
    }
  }
}
